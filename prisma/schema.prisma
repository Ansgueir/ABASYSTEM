generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  passwordHash        String
  role                UserRole
  isActive            Boolean             @default(true)
  isHidden            Boolean             @default(false)
  isFirstLogin        Boolean             @default(true)
  onboardingCompleted Boolean             @default(false)
  onboardingStep      Int                 @default(0)
  signatureUrl        String?
  initialsUrl         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  requiresWizard      Boolean             @default(false)
  inviteSent          Boolean             @default(false)
  uploadedDocuments   Document[]
  officeMember        OfficeMember?
  repeatingSchedules  RepeatingSchedule[]
  student             Student?
  supervisor          Supervisor?
  notifications       Notification[]
  auditLogs           AuditLog[]
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id                     String                       @id @default(uuid())
  userId                 String                       @unique
  fullName               String
  paymentAlias           String[]
  bacbId                 String                       @db.VarChar(10)
  credential             CredentialType
  school                 String
  level                  LevelType
  phone                  String
  email                  String
  supervisorId           String?
  address                String                       @default("")
  city                   String
  state                  String
  startDate              DateTime
  supervisionType        SupervisionType
  fieldworkType          FieldworkType                @default(REGULAR)
  supervisionPercentage  Decimal
  hoursToDo              Int
  hoursToPay             Int
  amountToPay            Decimal                      @db.Decimal(10, 2)
  hourlyRate             Decimal                      @default(0) @db.Decimal(10, 2)
  hoursPerMonth          Int
  totalMonths            Int
  endDate                DateTime
  status                 StudentStatus                @default(ACTIVE)
  availableDaysGroup     String[]
  notes                  String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  academicDegree         String?
  contractStartDate      DateTime?
  contracts              Contract[]
  documents              Document[]
  groupAttendance        GroupSupervisionAttendance[]
  independentHours       IndependentHour[]
  invoices               Invoice[]
  supervisors            StudentSupervisor[]
  user                   User                         @relation(fields: [userId], references: [id])
  supervisor             Supervisor?                  @relation("PrimarySupervisor", fields: [supervisorId], references: [id])
  evaluations            StudentEvaluation[]
  payments               StudentPayment[]
  vcsSequence            String?
  assignedOptionPlan     String?
  planTemplateId         String?
  totalAmountContract    Decimal?                     @db.Decimal(10, 2)
  analystPaymentRate     Decimal?                     @db.Decimal(5, 4)
  officePaymentRate      Decimal?                     @db.Decimal(5, 4)
  internalComments       String?
  hoursTargetReg         Int?
  hoursTargetConc        Int?
  independentHoursTarget Int?

  importBatchId String?

  supervisionHours   SupervisionHour[]
  supervisorPayments SupervisorPayment[]
  financialPeriods   FinancialPeriod[]
  ledgerEntries      SupervisorLedgerEntry[]
  groupAssignments   GroupStudent[]

  @@index([fullName])
  @@index([email])
}

model Supervisor {
  id                 String                    @id @default(uuid())
  userId             String                    @unique
  fullName           String
  phone              String
  email              String
  address            String
  bacbId             String
  certificantNumber  String
  examDate           DateTime?
  training8hrDate    DateTime?
  availableDaysGroup String[]
  monthStarted       DateTime?
  internalIdNumber   String?
  dateQualified      DateTime?
  status             SupervisorStatus          @default(ACTIVE)
  companyName        String?
  taxId              String?
  bankName           String?
  routingNumber      String?
  accountNumber      String?
  canEnterGroupHours Boolean                   @default(false)
  rateRegular        Decimal?                  @db.Decimal(10, 2)
  rateConcentrated   Decimal?                  @db.Decimal(10, 2)
  paymentPercentage  Decimal?                  @db.Decimal(5, 4)
  comments           String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  credentialType     CredentialType            @default(BCBA)
  maxStudents        Int                       @default(10)
  documents          Document[]
  groupSessions      GroupSupervisionSession[]
  studentAssignments StudentSupervisor[]
  evaluations        StudentEvaluation[]
  supervisionHours   SupervisionHour[]
  user               User                      @relation(fields: [userId], references: [id])
  students           Student[]                 @relation("PrimarySupervisor")
  payments           SupervisorPayment[]
  contracts          ContractSupervisor[]
  ledgerEntries      SupervisorLedgerEntry[]
  payouts            SupervisorPayout[]
  managedGroups      SupervisorGroup[]
  officeGroups       OfficeGroupSupervisor[]
  contractGroupAssignments ContractGroupAssignment[]
  importBatchId      String?

  @@index([fullName])
  @@index([email])
}

model StudentSupervisor {
  id           String     @id @default(uuid())
  studentId    String
  supervisorId String
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id])

  @@unique([studentId, supervisorId])
  @@index([studentId])
  @@index([supervisorId])
}

model OfficeMember {
  id          String     @id @default(uuid())
  userId      String     @unique
  fullName    String
  officeRole  OfficeRole @default(ADMIN)
  permissions Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])

  @@index([fullName])
}

model IndependentHour {
  id                  String             @id @default(uuid())
  studentId           String
  date                DateTime
  startTime           DateTime
  hours               Decimal            @db.Decimal(4, 2)
  setting             SettingType
  customSetting       String?
  activityType        ActivityType
  notes               String?
  isRepeating         Boolean            @default(false)
  repeatingScheduleId String?
  status              HourStatus         @default(PENDING)
  rejectReason        String?
  createdAt           DateTime           @default(now())
  repeatingSchedule   RepeatingSchedule? @relation(fields: [repeatingScheduleId], references: [id])
  student             Student            @relation(fields: [studentId], references: [id])
}

model SupervisionHour {
  id                  String                   @id @default(uuid())
  studentId           String
  supervisorId        String
  date                DateTime
  startTime           DateTime
  hours               Decimal                  @db.Decimal(4, 2)
  supervisionType     SupervisionFormat
  setting             SettingType
  customSetting       String?
  activityType        ActivityType
  notes               String?
  groupTopic          String?
  isRepeating         Boolean                  @default(false)
  repeatingScheduleId String?
  status              HourStatus               @default(PENDING)
  rejectReason        String?
  amountBilled        Decimal?                 @db.Decimal(10, 2)
  supervisorPay       Decimal?                 @db.Decimal(10, 2)
  invoiceId           String?
  groupSessionId      String?
  createdAt           DateTime                 @default(now())
  invoice             Invoice?                 @relation(fields: [invoiceId], references: [id])
  groupSession        GroupSupervisionSession? @relation(fields: [groupSessionId], references: [id], onDelete: SetNull)
  repeatingSchedule   RepeatingSchedule?       @relation(fields: [repeatingScheduleId], references: [id])
  student             Student                  @relation(fields: [studentId], references: [id])
  supervisor          Supervisor               @relation(fields: [supervisorId], references: [id])
}

model RepeatingSchedule {
  id                      String            @id @default(uuid())
  userId                  String
  name                    String
  frequencyType           String
  frequencyValue          Int
  daysOfWeek              String[]
  endAfterOccurrences     Int?
  endDate                 DateTime?
  templateData            Json
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  createdIndependentHours IndependentHour[]
  user                    User              @relation(fields: [userId], references: [id])
  createdSupervisionHours SupervisionHour[]
}

model StudentPayment {
  id            String      @id @default(uuid())
  studentId     String
  paymentDate   DateTime
  amount        Decimal     @db.Decimal(10, 2)
  paymentType   PaymentType
  notes         String?
  importBatchId String?
  createdAt     DateTime    @default(now())
  student       Student     @relation(fields: [studentId], references: [id])
}

model SupervisorPayout {
  id           String   @id @default(uuid())
  invoiceId    String
  supervisorId String
  amount       Decimal  @db.Decimal(10, 2)
  method       String
  reference    String?
  notes        String?
  createdAt    DateTime @default(now())

  invoice    Invoice    @relation(fields: [invoiceId], references: [id])
  supervisor Supervisor @relation(fields: [supervisorId], references: [id])
}

model SupervisorPayment {
  id                  String     @id @default(uuid())
  supervisorId        String
  studentId           String
  monthYear           DateTime
  amountDue           Decimal    @db.Decimal(10, 2)
  amountPaidThisMonth Decimal    @db.Decimal(10, 2)
  amountAlreadyPaid   Decimal    @db.Decimal(10, 2)
  balanceDue          Decimal    @db.Decimal(10, 2)
  importBatchId       String?
  createdAt           DateTime   @default(now())
  student             Student    @relation(fields: [studentId], references: [id])
  supervisor          Supervisor @relation(fields: [supervisorId], references: [id])
}

model Invoice {
  id               String                  @id @default(uuid())
  studentId        String
  invoiceDate      DateTime
  amountDue        Decimal                 @db.Decimal(10, 2)
  amountPaid       Decimal                 @db.Decimal(10, 2)
  status           InvoiceStatus
  sentAt           DateTime?
  createdAt        DateTime                @default(now())
  student          Student                 @relation(fields: [studentId], references: [id])
  supervisionHours SupervisionHour[]
  ledgerEntries    SupervisorLedgerEntry[]
  payouts          SupervisorPayout[]
}

model SupervisorLedgerEntry {
  id                           String   @id @default(uuid())
  invoiceId                    String
  supervisorId                 String
  studentId                    String

  // ── WATERFALL AUTO (calculated when student pays) ───────────────────────
  paymentFromStudent           Decimal  @db.Decimal(10, 2) // Cuánto pagó el estudiante en esta transacción
  supervisorCapTotal           Decimal  @db.Decimal(10, 2) // Tope_Total_Supervisor = amountDue * commission%
  supervisorCapRemainingBefore Decimal  @db.Decimal(10, 2) // Remanente ANTES de este pago
  supervisorPayout             Decimal  @db.Decimal(10, 2) // Pago calculado al supervisor
  officePayout                 Decimal  @db.Decimal(10, 2) // Lo que se queda la oficina
  supervisorCapRemainingAfter  Decimal  @db.Decimal(10, 2) // Nuevo remanente DESPUÉS

  // ── PLAN SNAPSHOT (auto-filled from student plan at creation) ───────────
  planMonthlyPayment           Decimal? @db.Decimal(10, 2) // Plan.monthlyPayment
  planHoursPerMonth            Int?                         // Plan.hoursPerMonth
  planSupervisedHours          Decimal? @db.Decimal(8, 2)  // Plan.amountSupHours / numberOfMonths
  planIndividualHours          Decimal? @db.Decimal(8, 2)  // Plan.hoursPerMonth * (1 - supervisedPct)
  planIndividualSupervisedTarget Decimal? @db.Decimal(8, 2)  // Plan.individualSupervisedTarget
  planGroupSupervisionTarget      Decimal? @db.Decimal(8, 2)  // Plan.groupSupervisionTarget
  planIndividualSupervisedDelta  Decimal? @db.Decimal(8, 2)  // Plan.individualSupervisedDelta
  planGroupSupervisionDelta       Decimal? @db.Decimal(8, 2)  // Plan.groupSupervisionDelta

  // ── PAYOUT STATUS ────────────────────────────────────────────────────────
  payoutStatus                 String   @default("PENDING") // PENDING | PAID

  // ── MANUAL FIELDS (set by Super Office when paying supervisor) ──────────
  supervisedHoursActual        Decimal? @db.Decimal(8, 2)  // Horas supervisadas reales del mes
  individualHoursDelta         Decimal? @db.Decimal(8, 2)  // Delta horas individuales vs plan
  paymentMethod                String?                      // ZELLE | ACH | WIRE | CHECK | CASH
  paymentReference             String?                      // Número de confirmación / referencia
  paymentNotes                 String?                      // Notas internas
  paidAt                       DateTime?                    // Cuándo se ejecutó el pago

  createdAt                    DateTime @default(now())

  invoice    Invoice    @relation(fields: [invoiceId], references: [id])
  supervisor Supervisor @relation(fields: [supervisorId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@index([invoiceId])
  @@index([supervisorId])
  @@index([payoutStatus])
}

model Document {
  id              String         @id @default(uuid())
  studentId       String?
  supervisorId    String?
  documentType    DocumentType
  fileUrl         String
  fileName        String
  fileSize        Int
  uploadedById    String?
  uploadedAt      DateTime       @default(now())
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  student         Student?       @relation(fields: [studentId], references: [id])
  supervisor      Supervisor?    @relation(fields: [supervisorId], references: [id])
  uploadedBy      User?          @relation(fields: [uploadedById], references: [id])
}

model GroupSupervisionSession {
  id           String   @id @default(uuid())
  supervisorId String
  groupId      String?
  recurrenceId String?
  date         DateTime
  startTime    DateTime
  topic        String
  maxStudents  Int      @default(10)
  createdAt    DateTime @default(now())

  attendance       GroupSupervisionAttendance[]
  supervisionHours SupervisionHour[]

  supervisor Supervisor    @relation(fields: [supervisorId], references: [id])
  group      OfficeGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupSupervisionAttendance {
  id        String                  @id @default(uuid())
  sessionId String
  studentId String
  attended  Boolean                 @default(true)
  createdAt DateTime                @default(now())
  session   GroupSupervisionSession @relation(fields: [sessionId], references: [id])
  student   Student                 @relation(fields: [studentId], references: [id])
}

model StudentEvaluation {
  id             String             @id @default(uuid())
  studentId      String
  supervisorId   String
  monthYear      DateTime
  criteria       EvaluationCriteria
  evaluationText String?
  createdAt      DateTime           @default(now())
  student        Student            @relation(fields: [studentId], references: [id])
  supervisor     Supervisor         @relation(fields: [supervisorId], references: [id])
}

model Contract {
  id              String               @id @default(uuid())
  studentId       String
  effectiveDate   DateTime
  status          ContractStatus       @default(DRAFT)
  rejectionReason String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  student         Student              @relation(fields: [studentId], references: [id])
  supervisors     ContractSupervisor[]
  groupAssignments ContractGroupAssignment[]
}

model ContractSupervisor {
  id               String     @id @default(uuid())
  contractId       String
  supervisorId     String
  isMainSupervisor Boolean    @default(false)
  contract         Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  supervisor       Supervisor @relation(fields: [supervisorId], references: [id])

  @@unique([contractId, supervisorId])
}

model GeneralValues {
  id                          String   @id @default(uuid())
  rateRegular                 Decimal  @db.Decimal(10, 2)
  rateConcentrated            Decimal  @db.Decimal(10, 2)
  supervisorPaymentPercentage Decimal  @db.Decimal(5, 4)
  companyName                 String
  companyAddress              String
  companyPhone                String
  companyEmail                String
  companyWebsite              String   @default("")
  companyTaxId                String   @default("")
  companyLogoUrl              String   @default("")
  maxHoursPerMonth            Int      @default(130)
  restrictedAlertPercent      Int      @default(40)
  updatedAt                   DateTime @updatedAt
}

model FinancialPeriod {
  id                     String   @id @default(uuid())
  studentId              String
  periodNumber           Int
  monthYearLabel         String
  amountDueOffice        Decimal  @db.Decimal(10, 2)
  amountDueAnalyst       Decimal  @db.Decimal(10, 2)
  accumulatedDueOffice   Decimal  @db.Decimal(10, 2)
  accumulatedPaidOffice  Decimal  @db.Decimal(10, 2)
  accumulatedPaidAnalyst Decimal  @db.Decimal(10, 2)
  importBatchId          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, periodNumber])
}

enum UserRole {
  STUDENT
  SUPERVISOR
  OFFICE
  QA
}

enum CredentialType {
  RBT
  RBT_NOT_WORKING
  BCaBA
  LMHC
  NO_CREDENTIAL
  BCBA
  BCBA_D
}

enum LevelType {
  BCaBA
  BCBA
}

enum SupervisionType {
  REGULAR
  CONCENTRATED
}

enum StudentStatus {
  ACTIVE
  PENDING
  COMPLETED
  WITHDRAWN
  DISABLED
}

enum SupervisorStatus {
  ACTIVE
  WITHDRAWN
  DISABLED
}

enum SettingType {
  CLIENTS_HOME
  SCHOOL
  DAYCARE
  OFFICE_CLINIC
  GROUP_HOME
  COMMUNITY
  OTHERS
}

enum ActivityType {
  RESTRICTED
  UNRESTRICTED
}

enum SupervisionFormat {
  INDIVIDUAL
  GROUP
}

enum EvaluationCriteria {
  S
  NI
  U
  NA
}

enum PaymentType {
  ZELLE
  CHECK
  VENMO
  CASHAPP
  CASH
  PAYPAL
  BANK_TRANSFER
  CREDIT_CARD
}

enum DocumentType {
  IDENTIFICATION
  CLIENT_CONSENT
  PROOF_START_DATE
  ACADEMIC_DEGREE
  PREVIOUS_FINAL_FORM
  SIGNED_CONTRACT
  WC_EXEMPTION
  BACB_CERTIFICATION
  LIABILITY_INSURANCE
  OTHER_FORMAL_DOCUMENT
  OTHER
}

enum InvoiceStatus {
  READY_TO_GO
  SENT
  PAID
  OVERDUE
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SENT
  SIGNED
  REJECTED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OfficeRole {
  SUPER_ADMIN
  ADMIN
}

enum NotificationType {
  SYSTEM
  CONTRACT
  DOCUMENT
  HOURS
}

enum HourStatus {
  PENDING
  APPROVED
  REJECTED
  BILLED
}

enum FieldworkType {
  REGULAR
  CONCENTRATED
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userEmail String?
  action    String
  entity    String
  entityId  String?
  details   String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

model ImportBatch {
  id          String      @id @default(uuid())
  batchString String
  createdAt   DateTime    @default(now())
  status      String      @default("COMPLETED")
  revertedAt  DateTime?
  logs        ImportLog[]
}

model ImportLog {
  id        String      @id @default(uuid())
  batchId   String
  tableName String
  recordId  String
  action    String      @default("UPDATE")
  oldData   Json?
  newData   Json?
  batch     ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Plan {
  id            String   @id @default(uuid())
  name          String   @unique
  fieldworkType String   @default("REGULAR") // REGULAR or CONCENTRATED

  // ── INPUT VARIABLES (editable by Super Office) ──────────────────────────
  totalHours            Int?     // Total fieldwork hours (e.g. 1500)
  hoursPerMonth         Int?     // Hours student can complete per month (e.g. 130)
  supervisedPercentage  Decimal? @db.Decimal(5, 4) // e.g. 0.05 = 5%
  hourlyRate            Decimal? @db.Decimal(10, 2) // Cost per supervision hour
  enrollmentFee         Decimal? @db.Decimal(10, 2) // Matrícula (one-time fee)
  supervisorCommission  Decimal? @db.Decimal(5, 4) // e.g. 0.60 = 60% to supervisor

  // ── AUTO-CALCULATED FIELDS (stored for snapshot integrity) ───────────────
  numberOfMonths        Int?     // ceil(totalHours / hoursPerMonth)
  amountSupHours        Decimal? @db.Decimal(10, 2) // totalHours * supervisedPercentage
  totalCost             Decimal? @db.Decimal(10, 2) // amountSupHours * hourlyRate
  supervisionNet        Decimal? @db.Decimal(10, 2) // totalCost - enrollmentFee
  monthlyPayment        Decimal? @db.Decimal(10, 2) // supervisionNet / numberOfMonths
  
  // ── SUPERVISION BREAKDOWN ────────────────────────────────────────────────
  individualSupervisedTarget Decimal? @db.Decimal(10, 2)
  groupSupervisionTarget      Decimal? @db.Decimal(10, 2)

  // ── LEGACY FIELDS (kept for backward compat) ────────────────────────────
  regHoursBcba  Int      @default(0)
  regHoursBcaba Int      @default(0)
  concHours     Int      @default(0)
  totalCharge   Decimal  @default(0) @db.Decimal(10, 2)
  analystPayout Decimal  @default(0) @db.Decimal(10, 2)
  totalMonths   Int      @default(12)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SupervisorGroup {
  id           String   @id @default(uuid())
  supervisorId String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supervisor    Supervisor                @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  students      GroupStudent[]

  @@unique([supervisorId, name])
  @@index([supervisorId])
}

model GroupStudent {
  id        String        @id @default(uuid())
  groupId   String
  studentId String
  startDate DateTime
  endDate   DateTime?
  status    StudentStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  group   SupervisorGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@index([groupId])
  @@index([studentId])
}

// ── OFFICE-MANAGED GROUPS (Settings > Grupos) ────────────────────────────────
model OfficeGroup {
  id        String   @id @default(uuid())
  name      String
  groupType String   // REGULAR | CONCENTRATED
  dayOfWeek String   // MONDAY | TUESDAY | WEDNESDAY | THURSDAY | FRIDAY | SATURDAY | SUNDAY
  startTime String   // HH:MM  24h
  endTime   String   // HH:MM  24h
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supervisors         OfficeGroupSupervisor[]
  contractAssignments ContractGroupAssignment[]
  groupSessions       GroupSupervisionSession[]

  // Enforce: only 1 REGULAR + 1 CONCENTRATED per day
  @@unique([groupType, dayOfWeek])
}

model OfficeGroupSupervisor {
  id           String   @id @default(uuid())
  groupId      String
  supervisorId String
  createdAt    DateTime @default(now())

  group      OfficeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  supervisor Supervisor  @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([groupId, supervisorId])
  @@index([groupId])
  @@index([supervisorId])
}

// ── CONTRACT GROUP ASSIGNMENTS ────────────────────────────────────────────────
model ContractGroupAssignment {
  id            String   @id @default(uuid())
  contractId    String
  supervisorId  String
  officeGroupId String
  createdAt     DateTime @default(now())

  contract    Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  supervisor  Supervisor  @relation(fields: [supervisorId], references: [id])
  officeGroup OfficeGroup @relation(fields: [officeGroupId], references: [id])

  @@unique([contractId, supervisorId, officeGroupId])
  @@index([contractId])
}
